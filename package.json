{
  "name": "electron-vue-app",
  "version": "1.0.0",
  "type": "module",
  "description": "Electron + Vue 3 桌面应用（兼容 Windows 7）",
  "author": "hades",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win --publish never",
    "build:mac": "vite build && electron-builder --mac --publish never",
    "build:linux": "vite build && electron-builder --linux --publish never",
    "generate:icons": "node scripts/generate-icons.mjs"
  },
  "build": {
    "appId": "com.example.electron-vue-app",
    "productName": "Electron Vue App",
    "directories": {
      "output": "release"
    },
    "publish": null,
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "22.3.27",
    "electron-builder": "24.13.3",
    "png2icons": "^2.0.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^5.4.0",
    "vue": "^3.4.0",
    "vue-tsc": "^3.3.5",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@lucide/vue": "^1.18.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.9.10",
    "shadcn-vue": "^2.7.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  }
}
